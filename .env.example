# Add in Netlify → Site configuration → Environment variables

# Groq API key — get free at console.groq.com
GROQ_API_KEY=gsk_...

# JWT secret — any long random string
JWT_SECRET=change-this-to-something-long-and-random

# Optional: seed user database (JSON string) for persistence across cold starts
# USERS_SEED={"users":[]}
